# pattern_docs.rq — one row per pattern with all fields for Alexander pattern doc.
# Drives templates/pattern_doc.md.tera (fanout by name → docs/patterns/{name}.md).
# ORDER BY ?id for stable, deterministic fanout ordering.
#
# NOTE: w4g:touchesObject is fetched via OPTIONAL so that any future pattern that
# temporarily lacks an object binding still appears in the output (with an empty
# objectNames aggregate) rather than being silently excluded.

PREFIX w4g: <https://wasm4games.dev/ontology#>

SELECT ?id ?name ?family ?lowering ?stateCard ?eventCode ?eventName ?otelSpan
       ?requiredStatus ?refusalStatus ?primitive ?doc ?authority
       (GROUP_CONCAT(DISTINCT ?objName; SEPARATOR=",") AS ?objectNames)
WHERE {
    ?pattern a w4g:Pattern ;
        w4g:id              ?id ;
        w4g:name            ?name ;
        w4g:family          ?family ;
        w4g:lowering        ?loweringNode ;
        w4g:stateCard       ?stateCard ;
        w4g:eventCode       ?eventCode ;
        w4g:eventName       ?eventName ;
        w4g:otelSpan        ?otelSpan ;
        w4g:requiredStatus  ?requiredStatus ;
        w4g:refusalStatus   ?refusalStatus ;
        w4g:primitive       ?primitive ;
        w4g:doc             ?doc ;
        w4g:authority       ?authority .
    ?loweringNode w4g:name ?lowering .
    OPTIONAL {
        ?pattern w4g:touchesObject ?obj .
        ?obj w4g:name ?objName .
    }
}
GROUP BY ?id ?name ?family ?lowering ?stateCard ?eventCode ?eventName ?otelSpan
         ?requiredStatus ?refusalStatus ?primitive ?doc ?authority
ORDER BY ?id
