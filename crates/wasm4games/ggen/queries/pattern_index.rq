# pattern_index.rq — one row per pattern with the fields needed to render src/patterns/mod.rs:
# module declarations, kernel re-exports, and the PATTERN_REGISTRY entries. Object kinds are
# aggregated into parallel comma-joined lists (codes and names) so the template can emit the
# `&[ObjectKind { code, name }]` slices. ORDER BY ?id for stable output.
#
# NOTE: w4g:touchesObject is fetched via OPTIONAL so that any future pattern that temporarily
# lacks an object binding still appears in the output (with empty objectCodes/objectNames lists)
# rather than being silently excluded. The template must guard against empty aggregates.

PREFIX w4g: <https://wasm4games.dev/ontology#>

SELECT ?id ?name ?lowering ?stateCard ?eventCode ?eventName ?otelSpan
       ?requiredStatus ?refusalStatus
       (GROUP_CONCAT(?objCode; SEPARATOR=",") AS ?objectCodes)
       (GROUP_CONCAT(?objName; SEPARATOR=",") AS ?objectNames)
WHERE {
    ?pattern a w4g:Pattern ;
        w4g:id            ?id ;
        w4g:name          ?name ;
        w4g:lowering      ?loweringNode ;
        w4g:stateCard     ?stateCard ;
        w4g:eventCode     ?eventCode ;
        w4g:eventName     ?eventName ;
        w4g:otelSpan      ?otelSpan ;
        w4g:requiredStatus ?requiredStatus ;
        w4g:refusalStatus ?refusalStatus .
    ?loweringNode w4g:name ?lowering .
    OPTIONAL {
        ?pattern w4g:touchesObject ?obj .
        ?obj w4g:code ?objCode ;
             w4g:name ?objName .
    }
}
GROUP BY ?id ?name ?lowering ?stateCard ?eventCode ?eventName ?otelSpan
         ?requiredStatus ?refusalStatus
ORDER BY ?id
