# ---------------------------------------------------------------------------
# Example 7: EvidenceChain — patterns 6,7,8,9
# ---------------------------------------------------------------------------
ex:EvidenceChain
    a w4g:Example ;
    ex:fileName        "evidence_chain" ;
    ex:title           "Evidence Chain" ;
    ex:description     "A focused deep-dive into the four evidence patterns — OCEL event log construction, OTel trace emission, deterministic replay, and receipt generation — demonstrating tamper-evident provenance for game events." ;
    ex:usesPattern     "6"^^xsd:integer ,
                       "7"^^xsd:integer ,
                       "8"^^xsd:integer ,
                       "9"^^xsd:integer .

# ---------------------------------------------------------------------------
# Example 8: QualityEngine — patterns 56-65
# ---------------------------------------------------------------------------
ex:QualityEngine
    a w4g:Example ;
    ex:fileName        "quality_engine" ;
    ex:title           "Quality Engine" ;
    ex:description     "Exercises the DfLSS quality subsystem and engine bridge layer — sigma level tracking, defect counting, CTQ parameter management, NPS scoring, quality gate enforcement, command opcodes, capability declarations, bridge state machine, payload encoding, and adapter wiring." ;
    ex:usesPattern     "56"^^xsd:integer ,
                       "57"^^xsd:integer ,
                       "58"^^xsd:integer ,
                       "59"^^xsd:integer ,
                       "60"^^xsd:integer ,
                       "61"^^xsd:integer ,
                       "62"^^xsd:integer ,
                       "63"^^xsd:integer ,
                       "64"^^xsd:integer ,
                       "65"^^xsd:integer .
