    w4g:authority "oracle predicate: matches waypoint_reached_reference for all inputs" ;
    w4g:touchesObject w4g:obj_player ;
    w4g:touchesObject w4g:obj_nav_node ;
    w4g:family "Pathfinding" .

w4g:heuristic_distance_estimated a w4g:Pattern ;
    w4g:id 23 ;
