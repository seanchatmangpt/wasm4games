    w4g:authority "oracle predicate: matches nps_score_bounded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_prompt ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "DfLSS / Quality" .

w4g:quality_gate_evaluated a w4g:Pattern ;
    w4g:id 60 ;
    w4g:name "quality_gate_evaluated" ;
    w4g:lowering w4g:Dfa ;
    w4g:stateCard 4 ;
    w4g:eventCode 122 ;
    w4g:eventName "QualityGateEvaluated" ;
    w4g:otelSpan 122 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::dfa::dfa_advance" ;
