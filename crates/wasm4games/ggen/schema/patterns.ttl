    w4g:authority "oracle predicate: matches heuristic_distance_estimated_reference for all inputs" ;
    w4g:touchesObject w4g:obj_nav_node ;
    w4g:family "Pathfinding" .

w4g:path_cost_bounded a w4g:Pattern ;
