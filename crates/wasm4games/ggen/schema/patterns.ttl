    w4g:lowering w4g:Lut ;
    w4g:stateCard 8 ;
    w4g:eventCode 113 ;
    w4g:eventName "TickDeltaBounded" ;
    w4g:otelSpan 113 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::fix::clamp_u32" ;
    w4g:doc "Clamp a tick delta to a max_jitter window to prevent large desync jumps." ;
    w4g:authority "oracle predicate: matches tick_delta_bounded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_peer ;
    w4g:family "Multiplayer / Network" .

w4g:lag_compensation_applied a w4g:Pattern ;
    w4g:id 52 ;
    w4g:name "lag_compensation_applied" ;
    w4g:lowering w4g:Saturating ;
    w4g:stateCard 32 ;
    w4g:eventCode 114 ;
    w4g:eventName "LagCompensationApplied" ;
    w4g:otelSpan 114 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::int::saturating_sub_i64" ;
