    w4g:authority "oracle predicate: matches quality_gate_evaluated_reference for all inputs" ;
    w4g:touchesObject w4g:obj_quality_metric ;
    w4g:family "DfLSS / Quality" .

#################################################################
# Phase 2: Engine Bridge (ids 61-65, event codes 0x007B-0x007F)
#################################################################

w4g:command_opcode_encoded a w4g:Pattern ;
    w4g:id 61 ;
    w4g:name "command_opcode_encoded" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 123 ;
    w4g:eventName "CommandOpcodeEncoded" ;
    w4g:otelSpan 123 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::lt_mask_u32" ;
    w4g:doc "Encode a semantic command type (0..=127) into a platform opcode class via branchless boundary comparison." ;
    w4g:authority "oracle predicate: matches command_opcode_encoded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_engine_cmd ;
    w4g:family "Engine Bridge" .

w4g:capability_flag_evaluated a w4g:Pattern ;
    w4g:id 62 ;
    w4g:name "capability_flag_evaluated" ;
    w4g:lowering w4g:Bitset ;
    w4g:stateCard 32 ;
    w4g:eventCode 124 ;
    w4g:eventName "CapabilityFlagEvaluated" ;
    w4g:otelSpan 124 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::bitset::rank_u64" ;
    w4g:doc "Test whether a capability bit is set in a 64-bit capability flags word and return its rank (count of set bits at 0..=idx)." ;
    w4g:authority "oracle predicate: matches capability_flag_evaluated_reference for all inputs" ;
    w4g:touchesObject w4g:obj_engine_cmd ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "Engine Bridge" .

w4g:bridge_state_transitioned a w4g:Pattern ;
    w4g:id 63 ;
    w4g:name "bridge_state_transitioned" ;
    w4g:lowering w4g:Dfa ;
    w4g:stateCard 5 ;
    w4g:eventCode 125 ;
    w4g:eventName "BridgeStateTransitioned" ;
    w4g:otelSpan 125 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::dfa::dfa_advance" ;
    w4g:doc "Advance a platform bridge adapter FSM (DISCONNECTED/CONNECTING/CONNECTED/ERROR/RECOVERING) over a flat 5x5 table." ;
    w4g:authority "oracle predicate: matches bridge_state_transitioned_reference for all inputs" ;
    w4g:touchesObject w4g:obj_engine_cmd ;
    w4g:family "Engine Bridge" .

w4g:payload_size_bounded a w4g:Pattern ;
    w4g:id 64 ;
    w4g:name "payload_size_bounded" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 126 ;
    w4g:eventName "PayloadSizeBounded" ;
    w4g:otelSpan 126 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::min_u32" ;
    w4g:doc "Clamp a payload size request to the adapter's maximum MTU via branchless min; return clamped size and an overflow flag." ;
    w4g:authority "oracle predicate: matches payload_size_bounded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_engine_cmd ;
    w4g:family "Engine Bridge" .

w4g:adapter_priority_ranked a w4g:Pattern ;
    w4g:id 65 ;
    w4g:name "adapter_priority_ranked" ;
    w4g:lowering w4g:Network ;
    w4g:stateCard 8 ;
    w4g:eventCode 127 ;
    w4g:eventName "AdapterPriorityRanked" ;
    w4g:otelSpan 127 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::network::bitonic_sort_8u32" ;
    w4g:doc "Rank 4 adapter priorities using a branchless bitonic sort network on 8 slots; highest priority lands in bits[0..16]." ;
    w4g:authority "oracle predicate: matches adapter_priority_ranked_reference for all inputs" ;
    w4g:touchesObject w4g:obj_engine_cmd ;
    w4g:family "Engine Bridge" .

#################################################################
# Phase 2: AI Agent / Benchmark (ids 66-70, event codes 0x0080-0x0084)
#################################################################

w4g:reward_signal_clamped a w4g:Pattern ;
    w4g:id 66 ;
    w4g:name "reward_signal_clamped" ;
    w4g:lowering w4g:Saturating ;
    w4g:stateCard 32 ;
    w4g:eventCode 128 ;
    w4g:eventName "RewardSignalClamped" ;
    w4g:otelSpan 128 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::int::saturating_add_i64" ;
    w4g:doc "Clamp a raw RL reward signal to [-max_reward, +max_reward] for stability via saturating i64 intrinsics." ;
    w4g:authority "oracle predicate: matches reward_signal_clamped_reference for all inputs" ;
    w4g:touchesObject w4g:obj_agent ;
    w4g:family "AI Agent / Benchmark" .

w4g:policy_action_selected a w4g:Pattern ;
    w4g:id 67 ;
    w4g:name "policy_action_selected" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 129 ;
    w4g:eventName "PolicyActionSelected" ;
    w4g:otelSpan 129 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::select_u32" ;
    w4g:doc "Select the highest-value action from a policy's four Q-values, with first-index-wins tie-breaking." ;
    w4g:authority "oracle predicate: matches policy_action_selected_reference for all inputs" ;
    w4g:touchesObject w4g:obj_agent ;
    w4g:family "AI Agent / Benchmark" .

w4g:observation_class_selected a w4g:Pattern ;
    w4g:id 68 ;
    w4g:name "observation_class_selected" ;
    w4g:lowering w4g:Lut ;
    w4g:stateCard 8 ;
    w4g:eventCode 130 ;
    w4g:eventName "ObservationClassSelected" ;
    w4g:otelSpan 130 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::fix::clamp_u32" ;
    w4g:doc "Discretize a continuous observation value into one of N bins via integer division, clamped to [0, max_bins-1]." ;
    w4g:authority "oracle predicate: matches observation_class_selected_reference for all inputs" ;
    w4g:touchesObject w4g:obj_agent ;
    w4g:family "AI Agent / Benchmark" .

w4g:action_mask_applied a w4g:Pattern ;
    w4g:id 69 ;
    w4g:name "action_mask_applied" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 32 ;
    w4g:eventCode 131 ;
    w4g:eventName "ActionMaskApplied" ;
    w4g:otelSpan 131 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::select_u64" ;
    w4g:doc "Apply an action mask to a policy output — zero out Q-values for illegal actions via a branchless legality select." ;
    w4g:authority "oracle predicate: matches action_mask_applied_reference for all inputs" ;
    w4g:touchesObject w4g:obj_agent ;
    w4g:touchesObject w4g:obj_episode ;
    w4g:family "AI Agent / Benchmark" .

w4g:episode_return_bounded a w4g:Pattern ;
    w4g:id 70 ;
    w4g:name "episode_return_bounded" ;
    w4g:lowering w4g:Saturating ;
    w4g:stateCard 64 ;
    w4g:eventCode 132 ;
    w4g:eventName "EpisodeReturnBounded" ;
    w4g:otelSpan 132 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::int::saturating_add_i64" ;
    w4g:doc "Accumulate episodic return with a fixed-point discount factor, clamped to [0, max_return]." ;
    w4g:authority "oracle predicate: matches episode_return_bounded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_agent ;
    w4g:touchesObject w4g:obj_episode ;
    w4g:family "AI Agent / Benchmark" .

#################################################################
# Phase 3: Anti-Cheat detectors (ids 71-75, event codes 0x0085-0x0089)
#
# These are LEGALITY detectors, not value-kernels: the kernel returns a verdict
# bitmask (0 = ADMITTED/legal, nonzero = REFUSED/cheat). The w4g:authority slot
# carries the legality spec the verdict bit encodes; mustAdmit/mustRefuse seed
# the two-sided breed corpus (legal cases must verdict 0, cheat cases nonzero).
#################################################################

w4g:movement_legality_checked a w4g:Pattern ;
    w4g:id 71 ;
    w4g:name "movement_legality_checked" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 133 ;
    w4g:eventName "MovementLegalityChecked" ;
    w4g:otelSpan 133 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::lt_mask_u32" ;
    w4g:doc "Verdict bit0 set iff |proposed - current| exceeds max_speed (teleport cheat); a move at or under the budget is admitted." ;
    w4g:authority "legality spec: |proposed - cur| <= max_speed" ;
    w4g:mustAdmit "(100, 100 | (5 << 16))" ;
    w4g:mustAdmit "(100, 105 | (5 << 16))" ;
    w4g:mustAdmit "(200, 195 | (10 << 16))" ;
    w4g:mustRefuse "(100, 200 | (5 << 16))" ;
    w4g:mustRefuse "(200, 100 | (5 << 16))" ;
    w4g:mustRefuse "(0, 5000 | (10 << 16))" ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "Anti-Cheat" .

w4g:resource_bound_checked a w4g:Pattern ;
    w4g:id 72 ;
    w4g:name "resource_bound_checked" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 134 ;
    w4g:eventName "ResourceBoundChecked" ;
    w4g:otelSpan 134 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::lt_mask_u32" ;
    w4g:doc "Verdict bit0 set iff hp strictly exceeds hp_cap (resource-overflow cheat); hp at or under the cap is admitted." ;
    w4g:authority "legality spec: hp <= hp_cap" ;
    w4g:mustAdmit "(0, 100)" ;
    w4g:mustAdmit "(100, 100)" ;
    w4g:mustAdmit "(75, 100)" ;
    w4g:mustRefuse "(101, 100)" ;
    w4g:mustRefuse "(9999, 100)" ;
    w4g:mustRefuse "(1, 0)" ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "Anti-Cheat" .

w4g:cooldown_legality_checked a w4g:Pattern ;
    w4g:id 73 ;
    w4g:name "cooldown_legality_checked" ;
    w4g:lowering w4g:Bitset ;
    w4g:stateCard 2 ;
    w4g:eventCode 135 ;
    w4g:eventName "CooldownLegalityChecked" ;
    w4g:otelSpan 135 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::bitset::rank_u64" ;
    w4g:doc "Verdict bit0 mirrors the i16 sign bit of the remaining cooldown; a negative cooldown (fast-fire cheat) is refused." ;
    w4g:authority "legality spec: remaining_cooldown >= 0 (i16 sign bit clear)" ;
    w4g:mustAdmit "(0, 0)" ;
    w4g:mustAdmit "(1, 0)" ;
    w4g:mustAdmit "(0x7FFF, 0)" ;
    w4g:mustRefuse "((-1_i16 as u16) as u64, 0)" ;
    w4g:mustRefuse "(0x8000, 0)" ;
    w4g:mustRefuse "((-100_i16 as u16) as u64, 0)" ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "Anti-Cheat" .

w4g:action_rate_bounded a w4g:Pattern ;
    w4g:id 74 ;
    w4g:name "action_rate_bounded" ;
    w4g:lowering w4g:Mask ;
    w4g:stateCard 2 ;
    w4g:eventCode 136 ;
    w4g:eventName "ActionRateBounded" ;
    w4g:otelSpan 136 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::mask::lt_mask_u32" ;
    w4g:doc "Verdict bit0 set iff actions issued this tick strictly exceed the per-tick budget (action-spam/macro cheat)." ;
    w4g:authority "legality spec: actions_this_tick <= tick_budget" ;
    w4g:mustAdmit "(0, 8)" ;
    w4g:mustAdmit "(8, 8)" ;
    w4g:mustAdmit "(3, 8)" ;
    w4g:mustRefuse "(9, 8)" ;
    w4g:mustRefuse "(1000, 8)" ;
    w4g:mustRefuse "(1, 0)" ;
    w4g:touchesObject w4g:obj_player ;
    w4g:family "Anti-Cheat" .

w4g:transition_legality_checked a w4g:Pattern ;
    w4g:id 75 ;
    w4g:name "transition_legality_checked" ;
    w4g:lowering w4g:Dfa ;
    w4g:stateCard 5 ;
    w4g:eventCode 137 ;
    w4g:eventName "TransitionLegalityChecked" ;
    w4g:otelSpan 137 ;
    w4g:requiredStatus 4 ;
    w4g:refusalStatus 7 ;
    w4g:primitive "bcinr_logic::dfa::dfa_advance" ;
    w4g:doc "Verdict bit0 set iff the (from_state, symbol) DFA edge lands on the absorbing SINK state (forbidden/state-desync transition)." ;
    w4g:authority "legality spec: dfa_advance(from, symbol) != SINK (the edge is a legal protocol transition)" ;
    w4g:mustAdmit "(0, 0)" ;
    w4g:mustAdmit "(1, 1)" ;
    w4g:mustAdmit "(3, 2)" ;
    w4g:mustRefuse "(0, 2)" ;
    w4g:mustRefuse "(4, 0)" ;
    w4g:mustRefuse "(4, 1)" ;
    w4g:touchesObject w4g:obj_entity ;
    w4g:family "Anti-Cheat" .
