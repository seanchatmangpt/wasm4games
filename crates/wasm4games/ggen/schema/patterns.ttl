    w4g:authority "oracle predicate: matches path_cost_bounded_reference for all inputs" ;
    w4g:touchesObject w4g:obj_nav_node ;
    w4g:family "Pathfinding" .

w4g:nav_state_advanced a w4g:Pattern ;
    w4g:id 25 ;
