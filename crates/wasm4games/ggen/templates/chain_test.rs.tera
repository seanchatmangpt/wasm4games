{# chain_test.rs.tera — generates one #[cfg(test)] module per JTBD chain.
   Fanout by chainName; results contains all 8 steps for one chain, ordered by stepIndex.
   Available per row: chainName, jtbd, family, stepIndex, patternName, stateExpr, inputExpr, stepDoc.
   Step variables are named step1..step8 in sequence; stateExpr/inputExpr may reference
   earlier step variables (e.g. "step3") to express data dependencies between steps.
#}
{% for row in results %}
{% if loop.first %}
// GENERATED BY ggen — DO NOT EDIT. Source: ggen/schema/chains.ttl ({{ row.chainName }})
// Regenerate: `ggen sync`. JTBD: {{ row.jtbd }}

#[cfg(test)]
mod {{ row.chainName }}_chain {
    use crate::patterns::*;

    fn run_chain() -> u64 {
{% endif %}
        // Step {{ row.stepIndex }}: {{ row.stepDoc }}
        let step{{ row.stepIndex }} = {{ row.patternName }}({{ row.stateExpr }}, {{ row.inputExpr }});
{% if loop.last %}
        [step1, step2, step3, step4, step5, step6, step7, step8]
            .iter()
            .fold(0xcbf29ce484222325_u64, |h, &r| (h ^ r).wrapping_mul(0x100000001b3_u64))
    }

    #[test]
    fn chain_deterministic() {
        assert_eq!(run_chain(), run_chain(), "JTBD chain must be deterministic");
    }
}
{% endif %}
{% endfor %}
