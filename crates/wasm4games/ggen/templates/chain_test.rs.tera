{# chain_test.rs.tera — generates one test module per JTBD chain.

   For fanout rules, ggen injects the current row's fields as top-level variables.
   `chainName`, `jtbd`, `family` are the top-level vars for the current chain.
   `results` contains ALL steps across ALL chains; we filter using an {% if %} guard
   to emit only the steps that belong to the current chain.

   Available per row: chainName, jtbd, family, stepIndex, patternName, stateExpr, inputExpr, stepDoc.
   Step variables are named step1..stepN in sequence; stateExpr/inputExpr may reference
   earlier step variables (e.g. "step3") to express data dependencies between steps.
#}
// GENERATED BY ggen — DO NOT EDIT. Source: ggen/schema/chains.ttl ({{ chainName }})
// Regenerate: `ggen sync`. JTBD: {{ jtbd }}

#[cfg(test)]
mod {{ chainName }}_chain {
    use crate::patterns::*;

    fn run_chain() -> u64 {
{%- for step in results %}
{%- if step.chainName == chainName %}
        // Step {{ step.stepIndex }}: {{ step.stepDoc }}
        let step{{ step.stepIndex }} = {{ step.patternName }}({{ step.stateExpr }}, {{ step.inputExpr }});
{%- endif %}
{%- endfor %}
        // Fold all step outputs into a single FNV-1a hash so any change in any kernel
        // output is immediately visible as a test failure.
        [{%- for step in results %}{% if step.chainName == chainName %}step{{ step.stepIndex }}, {% endif %}{%- endfor %}]
            .iter()
            .fold(0xcbf29ce484222325_u64, |h, &r| (h ^ r).wrapping_mul(0x100000001b3_u64))
    }

    /// Chain must produce the same result on every call (no hidden mutable state).
    #[test]
    fn chain_deterministic() {
        assert_eq!(run_chain(), run_chain(), "JTBD chain must be deterministic");
    }

    /// Pin test: asserts a known-good hash so silent kernel regressions are caught.
    ///
    /// The committed chain file replaces `EXPECTED_HASH` with the real value.
    /// A sentinel of `u64::MAX` signals "not yet pinned" and always fails loudly.
    #[test]
    fn chain_hash_is_stable() {
        // REPLACE_EXPECTED_HASH: fill in the value printed by `cargo test -- --nocapture`.
        const EXPECTED_HASH: u64 = u64::MAX; // sentinel — must be replaced in committed chain
        assert_ne!(
            EXPECTED_HASH, u64::MAX,
            "chain_hash_is_stable: EXPECTED_HASH is still the sentinel — \
             run the test with --nocapture to obtain the real hash and pin it"
        );
        assert_eq!(run_chain(), EXPECTED_HASH, "chain output hash changed — re-pin or investigate");
    }
}
