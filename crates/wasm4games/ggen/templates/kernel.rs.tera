{# kernel.rs.tera — renders one branchless kernel file per pattern row.

   NOTE ON FIDELITY: every output file carries the GENERATED banner below, and the body
   follows the canonical `damage_applied` convention: a packed-u64 kernel, a branchful
   `_reference` oracle, two mutants, proptest equivalence + cf1/cf3 (cf2/wrapping_add dropped as redundant), a boundaries test,
   a two-sided breed battery (must_admit/must_refuse/weakened corpus with
   corpus_admit_matches_oracle / corpus_refuse_matches_oracle / weakened_fails_refuse_corpus),
   and a `bench` module. This template hard-codes the representative saturating-damage shape
   in clearly-marked sections; the committed, hand-finished kernels under src/patterns/ are
   the offline source of truth and may specialize the lowering body, ABI, oracle, and corpus
   per pattern. The five Anti-Cheat detector kernels (ids 71-75) specialize the two-sided
   block into the legality-verdict form (two_sided_admit / two_sided_refuse /
   weakened_fails_corpus). Render with: one output file per row keyed by `row.name`.

   Available fields per `row`: id, name, lowering, stateCard, eventCode, eventName, otelSpan,
   requiredStatus, refusalStatus, primitive, doc, authority, mustAdmit, mustRefuse.
   `mustAdmit`/`mustRefuse` are ` || `-joined `(state, input)` fixtures from the ontology
   (may be empty; the representative corpus below is used as the fallback).
#}
{% for row in results %}
// GENERATED BY ggen — DO NOT EDIT. Source: ggen/schema/patterns.ttl ({{ row.name }})
// Regenerate: `ggen sync`. Lowering: {{ row.lowering }}.
#![forbid(unsafe_code)]

//! Pattern: {{ row.eventName }}
//!
//! # Branchless Contract
//! **Ensures:** result matches the reference oracle for all inputs.
//! **Invariant:** execution path is independent of input data values (Branchless).
//!
//! # Timing contract
//! - T0 primitive budget: ~1 ns. T1 aggregate: <= 200 ns. Max heap allocations: 0.
//!
//! Authority: {{ row.authority }}.
//!
//! {{ row.doc }}

// === lowering imports (specialized per pattern in the committed kernel) ===
use {{ row.primitive }};

/// Branchless kernel for the **{{ row.eventName }}** pattern (id {{ row.id }}).
///
/// Operates on packed `u64` state and `u64` input using the $\mathcal{B}$-Calculus
/// primitives. This function is branchless: no conditional jumps are emitted.
///
/// # Pattern Family
///
/// {{ row.lowering }}
///
/// # Examples
///
/// ```
/// use wasm4games::patterns::{{ row.name }};
/// // State encodes the packed domain state ({{ row.stateCard }}-bit cardinality).
/// // Input encodes the event payload (see committed kernel for field layout).
/// // {{ row.doc }}
/// let new_state = {{ row.name }}(/* initial state */ 0, /* input */ 0);
/// assert!(new_state != u64::MAX, "sentinel for invalid state");
/// ```
///
/// # Formal Verification
///
/// Hoare-logic proof is present in the test oracle below.
/// See `ggen/schema/patterns.ttl` for the ontology entry.
///
/// Authority: {{ row.authority }}.
#[must_use = "pattern kernel — the returned state IS the result; ignoring it discards the computation"]
#[inline(always)]
pub fn {{ row.name }}(state: u64, input: u64) -> u64 {
    // === REPRESENTATIVE LOWERING BODY (saturating-damage shape) ===
    // The committed kernel replaces this with the pattern-specific branchless lowering.
    let hp = (state & 0xFFFF) as i64;
    let dmg = (input & 0xFFFF) as i64;
    let new_hp = hp.saturating_sub(dmg).max(0);
    (new_hp as u64) & 0xFFFF
}

#[cfg(test)]
mod tests {
    use super::*;
    use proptest::prelude::*;

    // --- Falsification battery ---
    // Any change to the kernel that changes output on these inputs is a regression.

    fn {{ row.name }}_reference(state: u64, input: u64) -> u64 {
        // === REPRESENTATIVE BRANCHFUL ORACLE ===
        let hp = (state & 0xFFFF) as i64;
        let dmg = (input & 0xFFFF) as i64;
        let r = hp - dmg;
        (if r < 0 { 0 } else { r } as u64) & 0xFFFF
    }
    fn mutant_1(s: u64, i: u64) -> u64 {
        !{{ row.name }}_reference(s, i)
    }
    fn mutant_3(s: u64, i: u64) -> u64 {
        {{ row.name }}_reference(s, i) ^ 0xFFFF
    }

    proptest! {
        #[test]
        fn prop_equivalence_kernel_matches_oracle(s in any::<u64>(), i in any::<u64>()) {
            prop_assert_eq!({{ row.name }}_reference(s, i), {{ row.name }}(s, i));
        }
        #[test]
        fn prop_cf1_nonzero_output_differs_from_bitflip_mutant(s in any::<u64>(), i in any::<u64>()) {
            let r = {{ row.name }}_reference(s, i);
            if r != 0 { prop_assert!(r != mutant_1(s, i)); }
        }
        #[test]
        fn prop_cf3_nonzero_output_differs_from_xor_mutant(s in any::<u64>(), i in any::<u64>()) {
            let r = {{ row.name }}_reference(s, i);
            if r != 0 { prop_assert!(r != mutant_3(s, i)); }
        }
    }

    #[test]
    fn boundaries_zero_and_max_match_oracle() {
        assert_eq!({{ row.name }}(0, 0), {{ row.name }}_reference(0, 0));
        assert_eq!(
            {{ row.name }}(0xFFFF, 0xFFFF),
            {{ row.name }}_reference(0xFFFF, 0xFFFF)
        );
    }

    // === Two-sided breed-rigor battery ===
    // Declared in the ontology as w4g:mustAdmit / w4g:mustRefuse; the committed kernel
    // specializes these `(state, input)` fixtures per pattern (detectors verdict 0 / nonzero;
    // value-kernels stay oracle-equal). The representative corpus below mirrors the
    // saturating-damage shape rendered above.
    fn must_admit() -> &'static [(u64, u64)] {
        // Legal, in-domain hits: damage strictly below current HP (no flooring needed).
        &[(100, 7), (100, 7 | (1 << 16)), (5000, 1000)]
    }
    fn must_refuse() -> &'static [(u64, u64)] {
        // Extreme overkill: damage exceeds HP so the kernel must floor the result at 0.
        &[(0, 5), (10, 100 | (1 << 16))]
    }
    fn weakened(s: u64, i: u64) -> u64 {
        // Weakened: omits the floor (drops `.max(0)`), so overkill underflows the lane.
        let hp = (s & 0xFFFF) as i64;
        let dmg = (i & 0xFFFF) as i64;
        let new_hp = hp.saturating_sub(dmg);
        (new_hp as u64) & 0xFFFF
    }
    #[test]
    fn corpus_admit_matches_oracle() {
        for &(s, i) in must_admit() {
            assert_eq!({{ row.name }}(s, i), {{ row.name }}_reference(s, i));
        }
    }
    #[test]
    fn corpus_refuse_matches_oracle() {
        for &(s, i) in must_refuse() {
            assert_eq!({{ row.name }}(s, i), {{ row.name }}_reference(s, i));
        }
    }
    #[test]
    fn weakened_fails_refuse_corpus() {
        assert!(
            must_refuse()
                .iter()
                .any(|&(s, i)| weakened(s, i) != {{ row.name }}_reference(s, i)),
            "a weakened impl must diverge from the oracle on >=1 refuse case"
        );
    }
}

#[cfg(feature = "bench")]
pub mod bench {
    use super::*;
    use criterion::{black_box, Criterion};
    pub fn bench_{{ row.name }}(c: &mut Criterion) {
        c.bench_function("{{ row.name }}", |b| {
            b.iter(|| black_box({{ row.name }}(black_box(100), black_box(7))))
        });
    }
}

