#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct OcelSchemaEdge {
    /// Pattern id the edge belongs to.
    pub pattern_id: u16,
    /// Activity (event) code.
    pub activity: u16,
    /// Object-type code linked by the activity.
    pub object_type: u16,
}

impl OcelSchemaEdge {
    /// Returns `true` if this edge matches the given activity and object-type codes.
    #[must_use]
    #[inline(always)]
    pub fn matches(&self, activity: u16, object_type: u16) -> bool {
        self.activity == activity && self.object_type == object_type
